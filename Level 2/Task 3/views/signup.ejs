<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'] },
          animation: {
            'shake': 'shake 0.4s cubic-bezier(.36,.07,.19,.97) both',
          },
          keyframes: {
            shake: {
              '10%, 90%': { transform: 'translate3d(-1px, 0, 0)' },
              '20%, 80%': { transform: 'translate3d(2px, 0, 0)' },
              '30%, 50%, 70%': { transform: 'translate3d(-4px, 0, 0)' },
              '40%, 60%': { transform: 'translate3d(4px, 0, 0)' },
            }
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="font-sans antialiased bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 transition-colors duration-500">

  <%- include('partials/navbar') %>

  <main class="min-h-screen flex items-center justify-center pt-24 pb-12 px-4 relative overflow-hidden">
    <!-- Background Decor -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none -z-10">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-violet-500/10 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-indigo-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="w-full max-w-md">
      <div class="bg-white dark:bg-gray-900 rounded-3xl shadow-2xl shadow-gray-200/50 dark:shadow-black/50 border border-gray-100 dark:border-gray-800 p-8 lg:p-10 animate-fade-in-up">
        
        <div class="text-center mb-8">
          <h1 class="text-3xl font-extrabold tracking-tight mb-2">Create your account</h1>
          <p class="text-gray-500 dark:text-gray-400 text-sm">Join 10,000+ creators building on Aether.</p>
        </div>

        <form id="signup-form" class="space-y-5" novalidate>
          <!-- Full Name -->
          <div>
            <label for="name" class="block text-sm font-semibold mb-2">Full Name</label>
            <div class="relative group">
              <input type="text" id="name" name="name" 
                class="w-full px-4 py-3 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 focus:border-violet-500 dark:focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 outline-none transition-all duration-200"
                placeholder="John Doe" required>
              <div class="error-msg hidden text-xs text-red-500 mt-1 pl-1">Name is required</div>
            </div>
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-semibold mb-2">Email Address</label>
            <div class="relative group">
              <input type="email" id="email" name="email" 
                class="w-full px-4 py-3 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 focus:border-violet-500 dark:focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 outline-none transition-all duration-200"
                placeholder="name@company.com" required>
              <div class="error-msg hidden text-xs text-red-500 mt-1 pl-1">Please enter a valid email</div>
            </div>
          </div>

          <!-- Password -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <label for="password" class="block text-sm font-semibold">Password</label>
              <button type="button" id="toggle-pw" class="text-xs font-medium text-violet-600 dark:text-violet-400 hover:text-violet-500">Show</button>
            </div>
            <div class="relative group">
              <input type="password" id="password" name="password" 
                class="w-full px-4 py-3 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 focus:border-violet-500 dark:focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 outline-none transition-all duration-200"
                placeholder="••••••••" required>
              
              <!-- Password Strength Bar -->
              <div class="mt-3 flex gap-1 h-1">
                <div class="strength-bar flex-1 bg-gray-200 dark:bg-gray-700 rounded-full transition-all duration-300"></div>
                <div class="strength-bar flex-1 bg-gray-200 dark:bg-gray-700 rounded-full transition-all duration-300"></div>
                <div class="strength-bar flex-1 bg-gray-200 dark:bg-gray-700 rounded-full transition-all duration-300"></div>
                <div class="strength-bar flex-1 bg-gray-200 dark:bg-gray-700 rounded-full transition-all duration-300"></div>
              </div>
              <div id="strength-text" class="text-[10px] uppercase tracking-wider font-bold text-gray-400 mt-1 transition-colors duration-300">Enter a password</div>
            </div>
          </div>

          <!-- Confirm Password -->
          <div>
            <label for="confirmPassword" class="block text-sm font-semibold mb-2">Confirm Password</label>
            <div class="relative group">
              <input type="password" id="confirmPassword" name="confirmPassword" 
                class="w-full px-4 py-3 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 focus:border-violet-500 dark:focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 outline-none transition-all duration-200"
                placeholder="••••••••" required>
              <div id="match-error" class="hidden text-xs text-red-500 mt-1 pl-1">Passwords do not match</div>
            </div>
          </div>

          <!-- Status Message -->
          <div id="status-message" class="hidden p-4 rounded-xl text-sm font-medium animate-fade-in-up"></div>

          <!-- Terms -->
          <div class="flex items-start gap-3 py-2 cursor-pointer" onclick="document.getElementById('terms').click()">
            <div class="relative flex items-center h-5">
              <input id="terms" name="terms" type="checkbox" required
                class="w-5 h-5 rounded-lg border-gray-300 dark:border-gray-700 text-violet-600 focus:ring-violet-500 cursor-pointer">
            </div>
            <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">
              I agree to the <a href="#" class="text-violet-600 dark:text-violet-400 font-semibold hover:underline">Terms of Service</a> and <a href="#" class="text-violet-600 dark:text-violet-400 font-semibold hover:underline">Privacy Policy</a>.
              <span id="terms-error" class="hidden block text-red-500 font-medium">You must agree to continue</span>
            </p>
          </div>

          <!-- Submit -->
          <button type="submit" id="submit-btn" class="w-full py-4 rounded-xl text-base font-bold text-white bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 shadow-xl shadow-violet-500/25 transition-all duration-300 hover:-translate-y-1 active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
            Create Account
          </button>
        </form>

        <div class="mt-8 text-center">
          <p class="text-sm text-gray-500 dark:text-gray-400">
            Already have an account? 
            <a href="#" class="text-violet-600 dark:text-violet-400 font-bold hover:underline">Sign in</a>
          </p>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
  <script>
    // Component Specific Logic for Signup
    const form = document.getElementById('signup-form');
    const nameInput = document.getElementById('name');
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');
    const termsCheck = document.getElementById('terms');
    const strengthBars = document.querySelectorAll('.strength-bar');
    const strengthText = document.getElementById('strength-text');
    const togglePw = document.getElementById('toggle-pw');

    // Toggle Password Visibility
    togglePw.addEventListener('click', () => {
      const isVisible = passwordInput.type === 'text';
      passwordInput.type = isVisible ? 'password' : 'text';
      togglePw.textContent = isVisible ? 'Show' : 'Hide';
    });

    // Real-time Name Validation
    nameInput.addEventListener('input', () => validateField(nameInput, val => val.trim().length > 0));

    // Real-time Email Validation
    emailInput.addEventListener('input', () => {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      validateField(emailInput, val => emailRegex.test(val));
    });

    // Password Strength Logic
    passwordInput.addEventListener('input', () => {
      const val = passwordInput.value;
      const strength = checkStrength(val);
      updateStrengthUI(strength);
      validateField(passwordInput, val => val.length >= 8);
    });

    function checkStrength(pw) {
      if (!pw) return 0;
      let score = 0;
      if (pw.length >= 8) score++;
      if (/[A-Z]/.test(pw)) score++;
      if (/[0-9]/.test(pw)) score++;
      if (/[^A-Za-z0-9]/.test(pw)) score++;
      return score;
    }

    function updateStrengthUI(score) {
      const configs = [
        { text: 'Too Weak', color: 'bg-red-500' },
        { text: 'Weak', color: 'bg-orange-500' },
        { text: 'Medium', color: 'bg-yellow-500' },
        { text: 'Strong', color: 'bg-emerald-500' }
      ];

      strengthBars.forEach((bar, i) => {
        bar.className = 'strength-bar flex-1 rounded-full transition-all duration-300 ' + 
          (i < score ? configs[score-1].color : 'bg-gray-200 dark:bg-gray-700');
      });

      if (score > 0) {
        strengthText.textContent = configs[score-1].text;
        strengthText.className = 'text-[10px] uppercase tracking-wider font-bold mt-1 ' + 
          configs[score-1].color.replace('bg-', 'text-');
      } else {
        strengthText.textContent = 'Enter a password';
        strengthText.className = 'text-[10px] uppercase tracking-wider font-bold text-gray-400 mt-1';
      }
    }

    function validateField(input, testFn) {
      const isValid = testFn(input.value);
      const errorMsg = input.parentElement.querySelector('.error-msg');
      
      if (!isValid && input.value !== "") {
        input.classList.add('border-red-500', 'ring-red-500/10');
        input.classList.remove('border-violet-500', 'border-gray-200');
        errorMsg?.classList.remove('hidden');
      } else {
        input.classList.remove('border-red-500', 'ring-red-500/10');
        input.classList.add('border-gray-200');
        errorMsg?.classList.add('hidden');
      }
      return isValid;
    }

    const confirmPasswordInput = document.getElementById('confirmPassword');
    const statusMessage = document.getElementById('status-message');
    const matchError = document.getElementById('match-error');

    // Detect selected plan from URL
    const urlParams = new URLSearchParams(window.location.search);
    const plan = urlParams.get('plan');
    if (plan) {
      const planBadge = document.createElement('div');
      planBadge.className = 'mt-4 inline-flex px-3 py-1 rounded-full bg-violet-100 dark:bg-violet-500/20 text-violet-600 dark:text-violet-400 text-[10px] font-bold uppercase tracking-widest';
      planBadge.textContent = `${plan} plan selected`;
      document.querySelector('.text-center.mb-8 h1').after(planBadge);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const isNameValid = validateField(nameInput, val => val.trim().length > 0);
      const isEmailValid = validateField(emailInput, val => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val));
      const isPwValid = validateField(passwordInput, val => val.length >= 8);
      const isMatch = passwordInput.value === confirmPasswordInput.value;
      const isTermsValid = termsCheck.checked;

      matchError.classList.toggle('hidden', isMatch);
      if (!isMatch) confirmPasswordInput.classList.add('border-red-500');

      if (isNameValid && isEmailValid && isPwValid && isMatch && isTermsValid) {
        const btn = document.getElementById('submit-btn');
        btn.disabled = true;
        btn.innerHTML = 'Creating account...';

        try {
          const response = await fetch('/signup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: nameInput.value,
              email: emailInput.value,
              password: passwordInput.value,
              confirmPassword: confirmPasswordInput.value
            })
          });

          const data = await response.json();

          if (data.success) {
            statusMessage.textContent = data.message;
            statusMessage.className = 'p-4 rounded-xl text-sm font-medium mb-6 bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20';
            statusMessage.classList.remove('hidden');
            setTimeout(() => window.location.href = '/dashboard', 2000);
          } else {
            throw new Error(data.message);
          }
        } catch (err) {
          statusMessage.textContent = err.message || 'Something went wrong. Please try again.';
          statusMessage.className = 'p-4 rounded-xl text-sm font-medium mb-6 bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-500/20';
          statusMessage.classList.remove('hidden');
          btn.disabled = false;
          btn.innerHTML = 'Create Account';
        }
      } else {
        form.parentElement.classList.add('animate-shake');
        setTimeout(() => form.parentElement.classList.remove('animate-shake'), 400);
      }
    });
  </script>
</body>
</html>
